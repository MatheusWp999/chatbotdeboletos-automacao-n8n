          "waitForSubWorkflow": false
        }
      },
      "id": "Exec_Responder_Cliente",
      "name": "Executar WF Cliente",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        700,
        320
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO mensagens (contato_id, direcao, conteudo, tipo) VALUES ({{$json.contato.id}}, 'entrada', {{$json.mensagem}}, 'texto');"
      },
      "id": "Pg_Log_Entrada",
      "name": "Log Mensagem Entrada",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        940,
