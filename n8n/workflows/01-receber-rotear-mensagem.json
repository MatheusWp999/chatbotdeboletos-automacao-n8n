{
  "name": "01 - Receber e Rotear Mensagem",
  "nodes": [
    {
      "parameters": {
        "path": "whatsapp",
        "httpMethod": "POST",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "Webhook_Entrada",
      "name": "Webhook WhatsApp",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -1180,
        220
      ]
    },
    {
      "parameters": {
        "language": "JavaScript",
        "jsCode": "const payload = $json.body || $json;\nconst data = payload.data || {};\nconst key = data.key || {};\nconst messageObj = data.message || {};\nconst msg = messageObj.conversation || messageObj.extendedTextMessage?.text || '';\nconst remote = (key.remoteJid || '').replace('@s.whatsapp.net', '');\nreturn [{\n  json: {\n    numero: remote.replace(/\\D/g, ''),\n    mensagem: msg,\n    tipo_mensagem: data.messageType || '',\n    eh_meu: Boolean(key.fromMe),\n    raw: payload\n  }\n}];"
      },
      "id": "Code_Extrair",
      "name": "Extrair Campos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -940,
        220
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.eh_meu}}",
              "operation": "isTrue"
            }
          ]
        }
      },
      "id": "If_Mensagem_Do_Bot",
      "name": "Ignorar Se fromMe",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -720,
        220
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM contatos WHERE numero_whatsapp = {{$json.numero}} LIMIT 1;"
      },
      "id": "Pg_Buscar_Contato",
      "name": "Buscar Contato",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        -500,
        340
      ],
      "credentials": {
        "postgres": {
          "id": "PG_BOT_BOLETOS",
          "name": "Postgres Bot Boletos"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.length}}",
              "operation": "larger",
              "value2": 0
            }
          ]
        }
      },
      "id": "If_Contato_Existe",
      "name": "Contato Encontrado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -260,
        340
      ]
    },
    {
      "parameters": {
        "url": "={{$env.EVOLUTION_API_URL}}/message/sendText/{{$env.EVOLUTION_INSTANCE_NAME}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.EVOLUTION_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{$node['Extrair Campos'].json.numero}}\",\n  \"text\": \"Ola! Voce nao esta cadastrado em nosso sistema.\"\n}"
      },
      "id": "Http_Nao_Cadastrado",
      "name": "Responder Nao Cadastrado",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -20,
        460
      ]
    },
    {
      "parameters": {
        "language": "JavaScript",
        "jsCode": "const contato = $json[0];\nif (!contato) return [{json: {}}];\nreturn [{json: { ...$node['Extrair Campos'].json, contato }}];"
      },
      "id": "Code_Normalizar_Contato",
      "name": "Normalizar Contato",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -20,
        220
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.contato.bot_ativo}}",
              "operation": "isFalse"
            }
          ]
        }
      },
      "id": "If_Bot_Ativo",
      "name": "Bot Esta Desligado?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        220,
        220
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.contato.tipo}}",
              "operation": "equals",
              "value2": "gerente"
            }
          ]
        }
      },
      "id": "If_Eh_Gerente",
      "name": "Contato e Gerente?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        460,
        220
      ]
    },
    {
      "parameters": {
        "workflowId": "04-notificacao-gerente",
